{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StagePal",
  "version": "../package.json",
  "identifier": "com.user.stagepal",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StagePal",
        "width": 1080,
        "height": 760,
        "minWidth": 720,
        "minHeight": 560,
        "visible": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
